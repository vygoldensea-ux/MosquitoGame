import { StatusBar } from 'expo-status-bar';
import React, { useEffect, useRef, useState, useCallback } from 'react';
import { StyleSheet, Text, View, Image, TouchableOpacity, Animated, Easing, Platform, Pressable, ScrollView, Alert, AppState } from 'react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { useFonts } from 'expo-font';
import * as SplashScreen from 'expo-splash-screen';
import { Audio } from 'expo-av';
import * as Haptics from 'expo-haptics';
import mobileAds, { BannerAd, BannerAdSize, TestIds } from 'react-native-google-mobile-ads';
import { AdMobConfig } from './config/admob';
import { IAP_PRODUCTS, PACK_DETAILS } from './config/iap';

// Removed JS require

const MAX_HEARTS = 5;
const TIME_PER_HEART = 15 * 60 * 1000;

SplashScreen.preventAutoHideAsync();

const SOUND_FILES: Record<string, any> = {
  bgmMain: require('../asset/sound/bgm-main.mp3'),
  splat: require('../asset/sound/sound-splat.mp3'),
  bossHit: require('../asset/sound/sound-boss-hit.mp3'),
  electric: require('../asset/sound/sound-electric.mp3'),
  coin: require('../asset/sound/sound-coin.mp3'),
  win: require('../asset/sound/sound-win.mp3'),
  lose: require('../asset/sound/sound-lose.mp3'),
};

// Will be read from App state via module-level refs so playSound/triggerVibration can access them
let _isSoundEnabled = true;
let _isVibrationEnabled = true;

const playSound = async (type: keyof typeof SOUND_FILES) => {
  if (!_isSoundEnabled) return;
  try {
    const { sound } = await Audio.Sound.createAsync(SOUND_FILES[type], { shouldPlay: true });
    sound.setOnPlaybackStatusUpdate((status: any) => {
      if (status.didJustFinish) {
        sound.unloadAsync();
      }
    });
  } catch (error) {
    console.log('Audio play error:', error);
  }
};

const triggerVibration = (style: 'light' | 'heavy' | 'success' | 'error') => {
  if (!_isVibrationEnabled) return;
  try {
    if (style === 'light') Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Light);
    else if (style === 'heavy') Haptics.impactAsync(Haptics.ImpactFeedbackStyle.Heavy);
    else if (style === 'success') Haptics.notificationAsync(Haptics.NotificationFeedbackType.Success);
    else if (style === 'error') Haptics.notificationAsync(Haptics.NotificationFeedbackType.Error);
  } catch { }
};

// ─── GameSwitch Component ──────────────────────────────────────────────────────
const GameSwitch = ({ value, onValueChange }: { value: boolean; onValueChange: (v: boolean) => void }) => (
  <TouchableOpacity
    activeOpacity={0.8}
    onPress={() => onValueChange(!value)}
    style={{
      width: 54, height: 28, borderRadius: 14,
      backgroundColor: value ? '#32CD32' : '#8B0000',
      borderWidth: 3, borderColor: '#000', justifyContent: 'center', paddingHorizontal: 2,
    }}
  >
    <View style={{
      width: 18, height: 18, borderRadius: 9, backgroundColor: '#FFF',
      borderWidth: 2, borderColor: '#000', alignSelf: value ? 'flex-end' : 'flex-start',
    }} />
  </TouchableOpacity>
);

export default function App() {
  const [fontsLoaded] = useFonts({
    'LuckiestGuy': require('../asset/fonts/LuckiestGuy-Regular.ttf'), // Font was loaded in asset/fonts earlier
  });

  // Initialize AdMob
  useEffect(() => {
    mobileAds()
      .initialize()
      .then(adapterStatuses => {
        console.log('AdMob initialized:', adapterStatuses);
      })
      .catch(error => {
        console.error('AdMob initialization error:', error);
      });
  }, []);

  // ═══════════════════════════════════════════════════════════
  // INITIALIZE IN-APP PURCHASES
  // ═══════════════════════════════════════════════════════════
  useEffect(() => {
    let purchaseListener: any = null;

    const initIAP = async () => {
      try {
        // Connect to store
        console.log('IAP connected (Mock)');

        // Get available products

        // Restore previous purchases (especially No Ads)
        await restorePurchases();

        // Listen for purchase updates
      } catch (error) {
        console.error('IAP initialization error:', error);
      }
    };

    initIAP();

    return () => {
      if (purchaseListener) {
        purchaseListener.remove();
      }
    };
  }, []);

  const [currentScreen, setCurrentScreen] = useState<'Start' | 'Loading' | 'Home' | 'Game'>('Start');
  const bgmSound = useRef<Audio.Sound | null>(null);
  const [hearts, setHearts] = useState(MAX_HEARTS);
  const [lastHeartLossTime, setLastHeartLossTime] = useState<number | null>(null);
  const [globalGold, setGlobalGold] = useState(0);
  const [currentLevel, setCurrentLevel] = useState(1);
  const [equippedSkin, setEquippedSkin] = useState('normal');
  const [inventory, setInventory] = useState<{ [key: string]: number }>({
    'item-racket': 0,
    'item-coil': 0,
    'item-spray': 0,
    'item-bomb': 0,
  });
  const [freeTrials, setFreeTrials] = useState<{ [key: string]: boolean }>({});
  const [isSoundEnabled, setIsSoundEnabled] = useState(true);
  const [isMusicEnabled, setIsMusicEnabled] = useState(true);
  const [isVibrationEnabled, setIsVibrationEnabled] = useState(true);
  const [isSettingsVisible, setIsSettingsVisible] = useState(false);
  const [isOutOfLivesModalVisible, setOutOfLivesModalVisible] = useState(false);
  const [isNoAdsPurchased, setIsNoAdsPurchased] = useState(false);
  const [adOverlayVisible, setAdOverlayVisible] = useState(false);
  const [adOverlayText, setAdOverlayText] = useState('');

  // ═══════════════════════════════════════════════════════════
  // RESTORE PURCHASES (for No Ads especially)
  // ═══════════════════════════════════════════════════════════
  const restorePurchases = async () => {
    try {
      const results: any[] = []; // Mocked for now

      if (results && results.length > 0) {
        // Check if any pack was purchased (all packs unlock No Ads)
        const hasAnyPack = results.some((purchase: any) =>
          Object.values(IAP_PRODUCTS).includes(purchase.productId)
        );

        if (hasAnyPack) {
          // User previously purchased a pack -> restore No Ads
          setIsNoAdsPurchased(true);
          await AsyncStorage.setItem('isNoAdsPurchased', 'true');
          console.log('No Ads restored from previous purchase');
        }
      }
    } catch (error) {
      console.error('Restore purchases error:', error);
    }
  };

  // ═══════════════════════════════════════════════════════════
  // HANDLE SUCCESSFUL PURCHASE
  // ═══════════════════════════════════════════════════════════
  const handlePurchaseSuccess = async (purchase: any) => {
    try {
      const productId = purchase.productId;
      const packDetails = PACK_DETAILS[productId];

      if (!packDetails) {
        console.error('Unknown product ID:', productId);
        return;
      }

      // ─────────────────────────────────────────────────────
      // GRANT NO ADS (Permanent)
      // ─────────────────────────────────────────────────────
      if (packDetails.rewards.noAds) {
        setIsNoAdsPurchased(true);
        await AsyncStorage.setItem('isNoAdsPurchased', 'true');
      }

      // ─────────────────────────────────────────────────────
      // GRANT ITEMS (Consumable)
      // ─────────────────────────────────────────────────────
      const newInventory = { ...inventory };
      Object.entries(packDetails.rewards.items).forEach(([itemKey, quantity]) => {
        newInventory[itemKey] = (newInventory[itemKey] || 0) + quantity;
      });
      updateInventory(newInventory);

      // ─────────────────────────────────────────────────────
      // GRANT SKINS (Permanent)
      // ─────────────────────────────────────────────────────
      if (packDetails.rewards.skins.length > 0) {
        // Equip the first skin from the pack
        const firstSkin = packDetails.rewards.skins[0];
        updateSkin(firstSkin);
      }

      // ─────────────────────────────────────────────────────
      // ACKNOWLEDGE PURCHASE (Required by stores)
      // ─────────────────────────────────────────────────────

      // ─────────────────────────────────────────────────────
      // SUCCESS FEEDBACK
      // ─────────────────────────────────────────────────────
      Alert.alert(
        '🎉 Purchase Complete!',
        `You received:\n• No Ads\n${Object.entries(packDetails.rewards.items)
          .map(([key, qty]) => `• ${qty}× ${key.split('-')[1]}`)
          .join('\n')}${packDetails.rewards.skins.length > 0
            ? '\n• ' + packDetails.rewards.skins.join(', ') + ' skin(s)'
            : ''
        }`,
        [{ text: 'Awesome!', style: 'default' }]
      );

      console.log('Purchase processed:', productId);
    } catch (error) {
      console.error('Handle purchase error:', error);
      Alert.alert('Error', 'Failed to process purchase. Please contact support.');
    }
  };

  // ═══════════════════════════════════════════════════════════
  // INITIATE PURCHASE (Called from Shop)
  // ═══════════════════════════════════════════════════════════
  const purchasePack = async (productId: string) => {
    try {
      // Start purchase flow
      console.log(`Simulating purchase for native pass-through: ${productId}`);
      // Purchase listener will handle completion
    } catch (error: any) {
      console.error('Purchase error:', error);

      if (error.code === 'E_USER_CANCELLED') {
        // User canceled - no alert needed
        console.log('Purchase canceled by user');
      } else {
        Alert.alert(
          'Purchase Failed',
          'Unable to complete purchase. Please try again.',
          [{ text: 'OK' }]
        );
      }
    }
  };

  // ─── Ad Manager (simulated) ──────────────────────────────────────────────
  const showInterstitialAd = (onFinished: () => void) => {
    if (typeof window !== 'undefined' && (window as any).__autoTestActive) {
      console.log('🧪 Test: Skip interstitial');
      onFinished();
      return;
    }
    if (isNoAdsPurchased) { onFinished(); return; } // skip ad if no-ads purchased
    setAdOverlayText('📺  Advertisement\nPlease wait 5s...');
    setAdOverlayVisible(true);
    setTimeout(() => {
      setAdOverlayVisible(false);
      onFinished();
    }, 5000);
  };

  const showRewardedAd = (onSuccess: () => void) => {
    if (typeof window !== 'undefined' && (window as any).__autoTestActive) {
      console.log('🧪 Test: Skip rewarded, give reward');
      setHearts(prev => Math.min(MAX_HEARTS, prev + 1));
      onSuccess();
      return;
    }
    // Rewarded ads always run (voluntary — for rewards)
    setAdOverlayText('🎁  Watching Video Ad\nPlease wait to earn your reward...');
    setAdOverlayVisible(true);
    setTimeout(() => {
      setAdOverlayVisible(false);
      onSuccess();
    }, 1500);
  };
  // ─── End Ad Manager ──────────────────────────────────────────────────────

  const handleWatchAdForLife = () => {
    showRewardedAd(() => {
      const newHearts = Math.min(MAX_HEARTS, hearts + 1);
      setHearts(newHearts);
      AsyncStorage.setItem('userHearts', newHearts.toString()).catch(() => { });
      setOutOfLivesModalVisible(false);
      if (newHearts > 0) setCurrentScreen('Game');
    });
  };

  // Computed countdown for Out of Lives modal
  const heartCountdownForModal = (() => {
    if (hearts >= MAX_HEARTS || lastHeartLossTime === null) return 'FULL';
    const timePassed = Date.now() - lastHeartLossTime;
    const timeRemaining = TIME_PER_HEART - (timePassed % TIME_PER_HEART);
    const s = Math.floor((timeRemaining / 1000) % 60);
    const m = Math.floor((timeRemaining / (1000 * 60)) % 60);
    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
  })();

  useEffect(() => {
    const loadData = async () => {
      try {
        const storedGold = await AsyncStorage.getItem('userGold');
        if (storedGold !== null) setGlobalGold(parseInt(storedGold, 10));

        const storedLevel = await AsyncStorage.getItem('userLevel');
        if (storedLevel !== null) setCurrentLevel(parseInt(storedLevel, 10));

        const storedSkin = await AsyncStorage.getItem('userEquippedSkin');
        if (storedSkin !== null) setEquippedSkin(storedSkin);

        const storedInventory = await AsyncStorage.getItem('userInventory');
        if (storedInventory !== null) setInventory(JSON.parse(storedInventory));

        const storedTrials = await AsyncStorage.getItem('freeTrials');
        if (storedTrials !== null) setFreeTrials(JSON.parse(storedTrials));

        const storedHearts = await AsyncStorage.getItem('userHearts');
        if (storedHearts !== null) setHearts(parseInt(storedHearts, 10));

        const storedLastTime = await AsyncStorage.getItem('lastHeartLossTime');
        if (storedLastTime !== null) setLastHeartLossTime(parseInt(storedLastTime, 10));

        // Load settings
        const storedSound = await AsyncStorage.getItem('settingSound');
        const storedMusic = await AsyncStorage.getItem('settingMusic');
        const storedVibration = await AsyncStorage.getItem('settingVibration');
        const soundVal = storedSound !== null ? storedSound === 'true' : true;
        const musicVal = storedMusic !== null ? storedMusic === 'true' : true;
        const vibVal = storedVibration !== null ? storedVibration === 'true' : true;
        setIsSoundEnabled(soundVal);
        setIsMusicEnabled(musicVal);
        setIsVibrationEnabled(vibVal);
        _isSoundEnabled = soundVal;
        _isVibrationEnabled = vibVal;

        const storedNoAds = await AsyncStorage.getItem('isNoAdsPurchased');
        if (storedNoAds === 'true') setIsNoAdsPurchased(true);

        calculateRecoveredHearts(
          storedHearts !== null ? parseInt(storedHearts, 10) : MAX_HEARTS,
          storedLastTime !== null ? parseInt(storedLastTime, 10) : null
        );
      } catch (error) {
        console.error("Error loading data", error);
      }
    };

    // Calculate recovery directly using passed parameters to bypass stale state issues on initial load
    const calculateRecoveredHearts = async (currentHearts: number, lastTime: number | null) => {
      if (currentHearts < MAX_HEARTS && lastTime !== null) {
        const timePassed = Date.now() - lastTime;
        const recovered = Math.floor(timePassed / TIME_PER_HEART);

        if (recovered > 0) {
          const newHearts = Math.min(MAX_HEARTS, currentHearts + recovered);
          setHearts(newHearts);
          await AsyncStorage.setItem('userHearts', newHearts.toString());

          if (newHearts === MAX_HEARTS) {
            setLastHeartLossTime(null);
            await AsyncStorage.removeItem('lastHeartLossTime');
          } else {
            const newLastTime = lastTime + (recovered * TIME_PER_HEART);
            setLastHeartLossTime(newLastTime);
            await AsyncStorage.setItem('lastHeartLossTime', newLastTime.toString());
          }
        }
      }
    };

    loadData();

    const loadBGM = async () => {
      try {
        const { sound } = await Audio.Sound.createAsync(
          SOUND_FILES.bgmMain,
          { shouldPlay: true, isLooping: true, volume: 0.5 }
        );
        bgmSound.current = sound;
      } catch (error) {
        console.log("Error loading BGM:", error);
      }
    };
    loadBGM();

    // Store current app state
    const appState = useRef(AppState.currentState);

    const subscription = AppState.addEventListener('change', nextAppState => {
      // Check if coming from background to foreground
      if (appState.current.match(/inactive|background/) && nextAppState === 'active') {
        // App has come to the foreground
        if (bgmSound.current) bgmSound.current.playAsync();

        // Recover hearts if applicable
        setHearts(currentH => {
          setLastHeartLossTime(lastT => {
            calculateRecoveredHearts(currentH, lastT);
            return lastT;
          });
          return currentH;
        });
      } else if (nextAppState.match(/inactive|background/)) {
        // App has gone to the background
        if (bgmSound.current) bgmSound.current.pauseAsync();
      }

      // Update current state ref
      appState.current = nextAppState;
    });

    return () => {
      subscription.remove();
      if (bgmSound.current) {
        bgmSound.current.unloadAsync();
      }
    };
  }, []);

  // Sync module-level refs whenever state changes
  useEffect(() => { _isSoundEnabled = isSoundEnabled; }, [isSoundEnabled]);
  useEffect(() => { _isVibrationEnabled = isVibrationEnabled; }, [isVibrationEnabled]);

  // BGM sync with isMusicEnabled
  useEffect(() => {
    if (!bgmSound.current) return;
    if (isMusicEnabled) {
      bgmSound.current.playAsync().catch(() => { });
    } else {
      bgmSound.current.pauseAsync().catch(() => { });
    }
  }, [isMusicEnabled]);

  const toggleSetting = async (key: string, value: boolean) => {
    try { await AsyncStorage.setItem(key, value.toString()); } catch { }
  };

  const updateGold = async (newAmount: number) => {
    setGlobalGold(newAmount);
    try {
      await AsyncStorage.setItem('userGold', newAmount.toString());
    } catch (error) {
      console.error("Error saving gold", error);
    }
  };

  const updateLevel = async (newLevel: number) => {
    setCurrentLevel(newLevel);
    try {
      await AsyncStorage.setItem('userLevel', newLevel.toString());
    } catch (error) {
      console.error("Error saving level", error);
    }
  };

  const updateSkin = async (newSkin: string) => {
    setEquippedSkin(newSkin);
    try {
      await AsyncStorage.setItem('userEquippedSkin', newSkin);
    } catch (error) {
      console.error("Error saving skin", error);
    }
  };

  const updateInventory = async (newInventory: { [key: string]: number }) => {
    setInventory(newInventory);
    try {
      await AsyncStorage.setItem('userInventory', JSON.stringify(newInventory));
    } catch (error) {
      console.error("Error saving inventory", error);
    }
  };

  const updateFreeTrials = async (newTrials: { [key: string]: boolean }) => {
    setFreeTrials(newTrials);
    try {
      await AsyncStorage.setItem('freeTrials', JSON.stringify(newTrials));
    } catch (error) {
      console.error("Error saving free trials", error);
    }
  };

  const onLayoutRootView = useCallback(async () => {
    if (fontsLoaded) {
      await SplashScreen.hideAsync();
    }
  }, [fontsLoaded]);

  if (!fontsLoaded) {
    return null;
  }

  const decreaseHeart = async () => {
    if (hearts <= 0) return;

    const newHearts = hearts - 1;
    setHearts(newHearts);
    await AsyncStorage.setItem('userHearts', newHearts.toString());

    if (hearts === MAX_HEARTS) {
      // Bắt đầu đếm giờ nếu đang đầy mới mất máu
      const now = Date.now();
      setLastHeartLossTime(now);
      await AsyncStorage.setItem('lastHeartLossTime', now.toString());
    }
  };

  const addHeart = async () => {
    if (hearts >= MAX_HEARTS) return;
    const newHearts = hearts + 1;
    setHearts(newHearts);
    await AsyncStorage.setItem('userHearts', newHearts.toString());
    if (newHearts === MAX_HEARTS) {
      setLastHeartLossTime(null);
      await AsyncStorage.removeItem('lastHeartLossTime');
    }
  };

  return (
    <View style={styles.outerContainer} onLayout={onLayoutRootView}>
      <StatusBar style="light" />

      {/* Khung điện thoại ảo */}
      <View style={styles.phoneFrame}>
        {currentScreen === 'Start' && <StartScreen onPlay={() => setCurrentScreen('Loading')} />}
        {currentScreen === 'Loading' && <LoadingScreen onFinish={() => setCurrentScreen('Home')} />}
        {currentScreen === 'Home' && <HomeScreen hearts={hearts} lastHeartLossTime={lastHeartLossTime} onPlay={() => { if (hearts > 0) { setCurrentScreen('Game'); } else { setOutOfLivesModalVisible(true); } }} onOpenLivesModal={() => setOutOfLivesModalVisible(true)} onOpenSettingsModal={() => setIsSettingsVisible(true)} globalGold={globalGold} updateGold={updateGold} currentLevel={currentLevel} updateSkin={updateSkin} equippedSkin={equippedSkin} inventory={inventory} updateInventory={updateInventory} purchasePack={purchasePack} isNoAdsPurchased={isNoAdsPurchased} />}
        {currentScreen === 'Game' && <GameScreen hearts={hearts} decreaseHeart={decreaseHeart} addHeart={addHeart} onBack={() => setCurrentScreen('Home')} globalGold={globalGold} updateGold={updateGold} currentLevel={currentLevel} updateLevel={updateLevel} equippedSkin={equippedSkin} inventory={inventory} updateInventory={updateInventory} freeTrials={freeTrials} updateFreeTrials={updateFreeTrials} showInterstitialAd={showInterstitialAd} showRewardedAd={showRewardedAd} isNoAdsPurchased={isNoAdsPurchased} />}

        {/* Settings Modal - inside phoneFrame so widths match game popups */}
        {isSettingsVisible && (
          <View style={styles.gamePopupOverlay}>
            <View style={[styles.failedPopup, { position: 'relative' }]}>
              <TouchableOpacity
                onPress={() => setIsSettingsVisible(false)}
                style={{ position: 'absolute', top: -15, right: -15, backgroundColor: '#4A0000', width: 44, height: 44, borderRadius: 22, borderWidth: 3, borderColor: '#000', justifyContent: 'center', alignItems: 'center', zIndex: 10 }}
              >
                <Text style={{ color: '#fff', fontFamily: 'LuckiestGuy', fontWeight: '900', fontSize: 18 }}>X</Text>
              </TouchableOpacity>
              <Text style={styles.failedTitle}>SETTINGS</Text>
              <View style={[styles.failedContentBox, { flexDirection: 'column', paddingVertical: 15 }]}>
                <View style={{ flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center', width: '100%', marginBottom: 15 }}>
                  <Text style={styles.settingsLabel}>SOUND</Text>
                  <GameSwitch value={isSoundEnabled} onValueChange={(v) => { setIsSoundEnabled(v); toggleSetting('settingSound', v); }} />
                </View>
                <View style={{ flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center', width: '100%', marginBottom: 15 }}>
                  <Text style={styles.settingsLabel}>MUSIC</Text>
                  <GameSwitch value={isMusicEnabled} onValueChange={(v) => { setIsMusicEnabled(v); toggleSetting('settingMusic', v); }} />
                </View>
                <View style={{ flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center', width: '100%' }}>
                  <Text style={styles.settingsLabel}>VIBRATION</Text>
                  <GameSwitch value={isVibrationEnabled} onValueChange={(v) => { setIsVibrationEnabled(v); toggleSetting('settingVibration', v); }} />
                </View>
              </View>
              <TouchableOpacity onPress={() => setIsSettingsVisible(false)} style={styles.tryAgainBtnWrapper}>
                <View style={styles.tryAgainBtn}>
                  <Text style={styles.tryAgainText}>PLAY</Text>
                </View>
              </TouchableOpacity>
            </View>
          </View>
        )}

        {/* Out of Lives Modal - inside phoneFrame so widths match game popups */}
        {isOutOfLivesModalVisible && (
          <View style={styles.gamePopupOverlay}>
            <View style={[styles.failedPopup, { position: 'relative' }]}>
              <TouchableOpacity
                onPress={() => setOutOfLivesModalVisible(false)}
                style={{ position: 'absolute', top: -15, right: -15, backgroundColor: '#4A0000', width: 44, height: 44, borderRadius: 22, borderWidth: 3, borderColor: '#000', justifyContent: 'center', alignItems: 'center', zIndex: 10 }}
              >
                <Text style={{ color: '#fff', fontFamily: 'LuckiestGuy', fontWeight: '900', fontSize: 18 }}>X</Text>
              </TouchableOpacity>
              <Text style={styles.failedTitle}>GET MORE LIVES</Text>
              <View style={[styles.failedContentBox, { flexDirection: 'column' }]}>
                <View style={{ position: 'relative', justifyContent: 'center', alignItems: 'center' }}>
                  <Image source={require('../asset/image/icon-heart-broken.png')} style={{ width: 100, height: 100 }} resizeMode="contain" />
                  <Text style={{
                    position: 'absolute', color: '#fff', fontFamily: 'LuckiestGuy', fontSize: 38,
                    textShadowColor: '#000', textShadowOffset: { width: 2, height: 2 }, textShadowRadius: 3,
                  }}>{hearts}</Text>
                  <View style={{ position: 'absolute', bottom: 5, right: 8, width: 28, height: 28, borderRadius: 14, backgroundColor: '#000', borderWidth: 2, borderColor: '#fff', justifyContent: 'center', alignItems: 'center' }}>
                    <Text style={{ color: '#fff', fontFamily: 'LuckiestGuy', fontSize: 16 }}>+</Text>
                  </View>
                </View>
                <Text style={[styles.settingsLabel, { marginTop: 12, marginBottom: 4 }]}>TIME TO NEXT LIFE:</Text>
                <View style={{ backgroundColor: '#000', borderRadius: 8, paddingHorizontal: 15, paddingVertical: 4 }}>
                  <Text style={{ color: '#fff', fontFamily: 'LuckiestGuy', fontSize: 16 }}>
                    {hearts >= MAX_HEARTS ? 'FULL' : heartCountdownForModal}
                  </Text>
                </View>
              </View>
              <TouchableOpacity onPress={handleWatchAdForLife} style={styles.tryAgainBtnWrapper}>
                <View style={[styles.tryAgainBtn, { flexDirection: 'row' }]}>
                  <Text style={[styles.tryAgainText, { marginRight: 8 }]}>PLAY</Text>
                  <Image source={require('../asset/image/icon-ads.png')} style={{ width: 22, height: 22 }} resizeMode="contain" />
                </View>
              </TouchableOpacity>
            </View>
          </View>
        )}
        {/* ── Global Ad Overlay ── */}
        {adOverlayVisible && (
          <View style={{ position: 'absolute', top: 0, left: 0, right: 0, bottom: 0, backgroundColor: 'rgba(0,0,0,0.92)', zIndex: 9999, elevation: 9999, justifyContent: 'center', alignItems: 'center', paddingHorizontal: 30 }}>
            <Text style={{ color: '#fff', fontFamily: 'LuckiestGuy', fontSize: 20, textAlign: 'center', lineHeight: 32 }}>{adOverlayText}</Text>
          </View>
        )}

        {/* ── Banner Ad ── */}
        {!isNoAdsPurchased && (
          <View style={{ position: 'absolute', bottom: 0, left: 0, right: 0, height: 50, backgroundColor: '#ccc', justifyContent: 'center', alignItems: 'center', zIndex: 500, elevation: 500 }}>
            <Text style={{ fontFamily: 'LuckiestGuy', fontSize: 13, color: '#555' }}>ADVERTISEMENT</Text>
          </View>
        )}
      </View>

    </View>
  );
}

// -----------------------------------------------------------------------------
// STARTSCREEN COMPONENT
// -----------------------------------------------------------------------------
function StartScreen({ onPlay }: { onPlay: () => void }) {
  const logoOpacity = useRef(new Animated.Value(0)).current;
  const logoScale = useRef(new Animated.Value(0.3)).current;
  const buttonOpacity = useRef(new Animated.Value(0)).current;
  const buttonTranslateY = useRef(new Animated.Value(30)).current;

  useEffect(() => {
    Animated.sequence([
      Animated.delay(300),
      Animated.parallel([
        Animated.timing(logoOpacity, { toValue: 1, duration: 600, useNativeDriver: true }),
        Animated.spring(logoScale, { toValue: 1, friction: 4, tension: 50, useNativeDriver: true }),
      ]),
      Animated.parallel([
        Animated.timing(buttonOpacity, { toValue: 1, duration: 400, useNativeDriver: true }),
        Animated.spring(buttonTranslateY, { toValue: 0, friction: 5, tension: 60, useNativeDriver: true }),
      ]),
    ]).start();
  }, []);

  return (
    <View style={styles.screenContainer}>
      <Animated.Image
        source={require('../asset/image/logo.png')}
        style={[styles.logo, { opacity: logoOpacity, transform: [{ scale: logoScale }] }]}
        resizeMode="contain"
      />
      <Animated.View style={[styles.buttonWrapper, { opacity: buttonOpacity, transform: [{ translateY: buttonTranslateY }] }]}>
        <View style={styles.buttonShadow} />
        <TouchableOpacity style={styles.buttonMain} activeOpacity={0.8} onPress={onPlay}>
          <Text style={styles.buttonText}>PLAY</Text>
        </TouchableOpacity>
      </Animated.View>
    </View>
  );
}

// -----------------------------------------------------------------------------
// LOADINGSCREEN COMPONENT
// -----------------------------------------------------------------------------
function LoadingScreen({ onFinish }: { onFinish: () => void }) {
  const mosquitoTranslateY = useRef(new Animated.Value(0)).current;
  const progressValue = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    // 1. Hiệu ứng muỗi lơ lửng vô hạn
    Animated.loop(
      Animated.sequence([
        Animated.timing(mosquitoTranslateY, {
          toValue: -15, // bay lên
          duration: 800,
          easing: Easing.inOut(Easing.ease),
          useNativeDriver: true,
        }),
        Animated.timing(mosquitoTranslateY, {
          toValue: 0, // hạ xuống
          duration: 800,
          easing: Easing.inOut(Easing.ease),
          useNativeDriver: true,
        }),
      ])
    ).start();

    // 2. Hiệu ứng thanh Progress bar chạy (0 -> 100%)
    Animated.timing(progressValue, {
      toValue: 100,
      duration: 2500,
      easing: Easing.linear,
      useNativeDriver: false, // width/height cannot use native driver
    }).start(({ finished }) => {
      if (finished) {
        onFinish(); // Chuyển cảnh khi chạy xong
      }
    });
  }, []);

  const progressWidth = progressValue.interpolate({
    inputRange: [0, 100],
    outputRange: ['0%', '100%'],
  });

  return (
    <View style={[styles.screenContainer, { backgroundColor: '#FFFFFF' }]}>
      {/* Ảnh muỗi ở giữa với hiệu ứng floating */}
      <Animated.Image
        source={require('../asset/image/loading.png')}
        style={[
          styles.loadingImage,
          { transform: [{ translateY: mosquitoTranslateY }] }
        ]}
        resizeMode="contain"
      />

      {/* Thanh Progress Bar ở dưới cùng */}
      <View style={styles.progressBarContainer}>
        <Animated.View style={[styles.progressBarFill, { width: progressWidth }]} />
      </View>
    </View>
  );
}

// -----------------------------------------------------------------------------
// REUSABLE COMPONENTS
// -----------------------------------------------------------------------------
function BounceButton({ onPress, children, style }: any) {
  const scale = useRef(new Animated.Value(1)).current;

  return (
    <Pressable
      onPress={onPress}
      // @ts-ignore: onHoverIn is supported in React Native Web
      onHoverIn={() => {
        if (Platform.OS === 'web') Animated.spring(scale, { toValue: 1.15, friction: 3, useNativeDriver: true }).start();
      }}
      // @ts-ignore
      onHoverOut={() => {
        Animated.spring(scale, { toValue: 1, friction: 5, useNativeDriver: true }).start();
      }}
      onPressIn={() => {
        Animated.spring(scale, { toValue: 0.9, friction: 5, useNativeDriver: true }).start();
      }}
      onPressOut={() => {
        Animated.spring(scale, { toValue: Platform.OS === 'web' ? 1.15 : 1, friction: 3, useNativeDriver: true }).start();
      }}
      style={style}
    >
      <Animated.View style={[{ transform: [{ scale }] }]}>
        {children}
      </Animated.View>
    </Pressable>
  );
}

// -----------------------------------------------------------------------------
// HOMESCREEN COMPONENT
// -----------------------------------------------------------------------------
function HomeScreen({ hearts, lastHeartLossTime, onPlay, onOpenLivesModal, onOpenSettingsModal, globalGold, updateGold, currentLevel, updateSkin, equippedSkin, inventory, updateInventory, purchasePack, isNoAdsPurchased }: { hearts: number, lastHeartLossTime: number | null, onPlay: () => void, onOpenLivesModal: () => void, onOpenSettingsModal: () => void, globalGold: number, updateGold: (v: number) => void, currentLevel: number, updateSkin: (s: string) => void, equippedSkin: string, inventory: { [key: string]: number }, updateInventory: (inv: { [key: string]: number }) => void, purchasePack: (productId: string) => Promise<void>, isNoAdsPurchased: boolean }) {
  const topBarOpacity = useRef(new Animated.Value(0)).current;
  const sidebarTranslateX = useRef(new Animated.Value(100)).current;
  const characterScale = useRef(new Animated.Value(0.5)).current;
  const bottomTranslateY = useRef(new Animated.Value(100)).current;

  const [isShopVisible, setIsShopVisible] = useState(false);
  const [countdownText, setCountdownText] = useState('');

  useEffect(() => {
    let intervalId: ReturnType<typeof setInterval>;

    if (hearts < MAX_HEARTS && lastHeartLossTime !== null) {
      intervalId = setInterval(() => {
        const timePassed = Date.now() - lastHeartLossTime;
        const timeRemaining = TIME_PER_HEART - (timePassed % TIME_PER_HEART);

        const seconds = Math.floor((timeRemaining / 1000) % 60);
        const minutes = Math.floor((timeRemaining / (1000 * 60)) % 60);

        setCountdownText(`${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`);
      }, 1000);
    } else {
      setCountdownText('');
    }

    return () => {
      if (intervalId) clearInterval(intervalId);
    };
  }, [hearts, lastHeartLossTime]);

  useEffect(() => {
    Animated.stagger(150, [
      Animated.timing(topBarOpacity, { toValue: 1, duration: 400, useNativeDriver: true }),
      Animated.spring(sidebarTranslateX, { toValue: 0, friction: 5, tension: 60, useNativeDriver: true }),
      Animated.spring(characterScale, { toValue: 1, friction: 4, tension: 50, useNativeDriver: true }),
      Animated.spring(bottomTranslateY, { toValue: 0, friction: 6, tension: 50, useNativeDriver: true }),
    ]).start();
  }, []);

  return (
    <View style={styles.homeContainer}>

      {/* 1. TOP BAR */}
      {!isShopVisible && (
        <Animated.View style={[styles.topBar, { opacity: topBarOpacity }]}>
          {/* Thanh Tiền */}
          <View style={styles.statBadge}>
            <Image source={require('../asset/image/icon-coin.png')} style={styles.statIconBadge} resizeMode="contain" />
            <View style={styles.statBadgeBackground}>
              <Text style={styles.statText}>{globalGold}</Text>
              <Image source={require('../asset/image/icon-plus.png')} style={styles.plusIcon} resizeMode="contain" />
            </View>
          </View>

          {/* Thanh Tim */}
          <TouchableOpacity style={styles.statBadge} onPress={onOpenLivesModal} activeOpacity={0.8}>
            <Image source={require('../asset/image/icon-heart.png')} style={styles.statIconBadge} resizeMode="contain" />
            <View style={[styles.statBadgeBackground, { paddingHorizontal: 5 }]}>
              {countdownText !== '' && <Text style={{ fontSize: 10, color: '#333', fontFamily: 'LuckiestGuy', marginRight: 5 }}>{countdownText}</Text>}
              <Text style={styles.statText}>{hearts}</Text>
              <Image source={require('../asset/image/icon-plus.png')} style={styles.plusIcon} resizeMode="contain" />
            </View>
          </TouchableOpacity>
        </Animated.View>
      )}

      {/* 2. RIGHT SIDEBAR */}
      {!isShopVisible && (
        <Animated.View style={[styles.rightSidebar, { transform: [{ translateX: sidebarTranslateX }] }]}>
          <BounceButton style={styles.sidebarButtonWrapper} onPress={onOpenSettingsModal}>
            <View style={styles.sidebarButtonShadow} />
            <View style={styles.sidebarButton}>
              <Image source={require('../asset/image/icon-settings.png')} style={styles.sidebarIcon} resizeMode="contain" />
            </View>
          </BounceButton>
          <BounceButton style={styles.sidebarButtonWrapper} onPress={() => setIsShopVisible(true)}>
            <View style={styles.sidebarButtonShadow} />
            <View style={styles.sidebarButton}>
              <Image source={require('../asset/image/icon-shop.png')} style={styles.sidebarIcon} resizeMode="contain" />
            </View>
          </BounceButton>
          <BounceButton style={styles.sidebarButtonWrapper}>
            <View style={styles.sidebarButtonShadow} />
            <View style={styles.sidebarButton}>
              <Image source={require('../asset/image/icon-ads.png')} style={styles.sidebarIcon} resizeMode="contain" />
            </View>
          </BounceButton>
        </Animated.View>
      )}

      {/* 3. CENTER KHU VỰC NHÂN VẬT */}
      {!isShopVisible && (
        <Animated.View style={[styles.centerArea, { transform: [{ scale: characterScale }] }]}>
          <BounceButton style={{ zIndex: 3 }}>
            <Image source={require('../asset/image/arrow-left.png')} style={styles.arrowIcon} resizeMode="contain" />
          </BounceButton>

          <View style={styles.characterWrapper}>
            <Image source={require('../asset/image/character.png')} style={styles.characterImage} resizeMode="contain" />
            {/* Bóng đổ dưới chân */}
            <View style={styles.characterShadow} />
          </View>

          <BounceButton style={{ zIndex: 3 }}>
            <Image source={require('../asset/image/arrow-right.png')} style={styles.arrowIcon} resizeMode="contain" />
          </BounceButton>
        </Animated.View>
      )}

      {/* 4. BOTTOM PLAY BUTTON */}
      {!isShopVisible && (
        <Animated.View style={[styles.homeBottomWrapper, { transform: [{ translateY: bottomTranslateY }] }]}>
          <View style={styles.buttonShadow} />
          <TouchableOpacity style={styles.buttonMain} activeOpacity={0.8} onPress={onPlay}>
            <Text style={styles.buttonText}>PLAY</Text>
          </TouchableOpacity>
        </Animated.View>
      )}

      {/* Shop Modal Overlay */}
      {isShopVisible && (
        <View style={styles.shopModalOverlay}>
          <ShopModal onClose={() => setIsShopVisible(false)} globalGold={globalGold} updateGold={updateGold} equippedSkin={equippedSkin} updateSkin={updateSkin} inventory={inventory} updateInventory={updateInventory} purchasePack={purchasePack} isNoAdsPurchased={isNoAdsPurchased} />
        </View>
      )}
    </View>
  );
}

// --- Shop Modal Component ---
function ShopModal({ onClose, globalGold, updateGold, equippedSkin, updateSkin, inventory, updateInventory, purchasePack, isNoAdsPurchased }: { onClose: () => void, globalGold: number, updateGold: (v: number) => void, equippedSkin: string, updateSkin: (s: string) => void, inventory: { [key: string]: number }, updateInventory: (inv: { [key: string]: number }) => void, purchasePack: (productId: string) => Promise<void>, isNoAdsPurchased: boolean }) {
  const [activeTab, setActiveTab] = useState<'ITEMS' | 'PACK'>('ITEMS');
  const scale = useRef(new Animated.Value(0.3)).current;
  const opacity = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.parallel([
      Animated.spring(scale, { toValue: 1, friction: 5, tension: 60, useNativeDriver: true }),
      Animated.timing(opacity, { toValue: 1, duration: 300, useNativeDriver: true })
    ]).start();
  }, []);

  const items = [
    { id: '1', name: 'Racket', price: '200', icon: require('../asset/image/item-racket.png'), status: 'buy' },
    { id: '2', name: 'Coil', price: '300', icon: require('../asset/image/item-coil.png'), status: 'buy' },
    { id: '3', name: 'Spray', price: '500', icon: require('../asset/image/item-spray.png'), status: 'buy' },
    { id: '4', name: 'Normal Hand', price: '0', icon: require('../asset/image/item-hand-normal.png'), status: 'equipped' },
    { id: '5', name: 'Red Nails', price: '1000', icon: require('../asset/image/item-hand-rednails.png'), status: 'buy' },
    { id: '6', name: 'Tattoo Hand', price: '2000', icon: require('../asset/image/item-hand-tattoo.png'), status: 'buy' },
    { id: '7', name: 'Duster', price: '???', icon: require('../asset/image/item-duster.png'), status: 'coming_soon' },
    { id: '8', name: 'Net', price: '???', icon: require('../asset/image/item-net.png'), status: 'coming_soon' },
    { id: '9', name: 'Empty', price: '', icon: null, status: 'empty' },
  ];

  const packs = [
    {
      id: 'p1',
      productId: IAP_PRODUCTS.STARTER_PACK,
      price: '$1.99',
      rewards: [
        { icon: require('../asset/image/icon-no-ads.png') },
        { icon: require('../asset/image/item-racket.png'), qty: 5 },
        { icon: require('../asset/image/item-coil.png'), qty: 5 }
      ]
    },
    {
      id: 'p2',
      productId: IAP_PRODUCTS.PRO_PACK,
      price: '$3.99',
      rewards: [
        { icon: require('../asset/image/icon-no-ads.png') },
        { icon: require('../asset/image/item-racket.png'), qty: 15 },
        { icon: require('../asset/image/item-coil.png'), qty: 15 },
        { icon: require('../asset/image/item-spray.png'), qty: 10 },
        { icon: require('../asset/image/item-hand-rednails.png') }
      ]
    },
    {
      id: 'p3',
      productId: IAP_PRODUCTS.MEGA_PACK,
      price: '$5.99',
      rewards: [
        { icon: require('../asset/image/icon-no-ads.png') },
        { icon: require('../asset/image/item-racket.png'), qty: 30 },
        { icon: require('../asset/image/item-coil.png'), qty: 30 },
        { icon: require('../asset/image/item-spray.png'), qty: 20 },
        { icon: require('../asset/image/item-hand-rednails.png') },
        { icon: require('../asset/image/item-hand-tattoo.png') }
      ]
    },
  ];

  const handleBuyItem = (item: any) => {
    if (item.status === 'buy') {
      const priceStr = item.price;
      const price = parseInt(priceStr, 10);
      if (globalGold < price) {
        Alert.alert('Not enough Gold!', 'Keep swatting mosquitoes to earn more!');
      } else {
        updateGold(globalGold - price);

        let newInventory = { ...inventory };
        if (item.id === '1') newInventory['item-racket'] += 1;
        else if (item.id === '2') newInventory['item-coil'] += 1;
        else if (item.id === '3') newInventory['item-spray'] += 1;
        else if (item.id === '5') updateSkin('rednails');
        else if (item.id === '6') updateSkin('tattoo');

        updateInventory(newInventory);
        Alert.alert('Success', `You bought ${item.name}!`);
      }
    }
  };

  const handleBuyPack = async (pack: any) => {
    try {
      // Show loading state
      Alert.alert(
        'Processing Purchase',
        'Opening payment dialog...',
        [],
        { cancelable: false }
      );

      // Initiate real IAP
      await purchasePack(pack.productId);

      // Success is handled by handlePurchaseSuccess in App component
      // No need for manual inventory updates here
    } catch (error) {
      console.error('Pack purchase error:', error);
      // Error alert handled in purchasePack function
    }
  };

  const renderItemsTab = () => (
    <ScrollView style={styles.itemsScrollContainer} showsVerticalScrollIndicator={false}>
      <View style={styles.itemsGridContainer}>
        {items.map((item) => {
          // ═══════════════════════════════════════════════════
          // EMPTY PLACEHOLDER CARD
          // ═══════════════════════════════════════════════════
          if (item.status === 'empty') {
            return (
              <View
                key={item.id}
                style={[
                  styles.itemCard,
                  {
                    borderColor: 'transparent',
                    backgroundColor: 'transparent'
                  }
                ]}
              />
            );
          }

          const isComingSoon = item.status === 'coming_soon';

          return (
            <View key={item.id} style={styles.itemCard}>
              <BounceButton
                style={{ width: '100%', height: '100%' }}
                onPress={() => {
                  if (!isComingSoon && item.status === 'buy') {
                    handleBuyItem(item);
                  }
                }}
              >
                {/* ═════════════════════════════════════════════ */}
                {/* ICON AREA - 140px height */}
                {/* ═════════════════════════════════════════════ */}
                <View
                  style={[
                    styles.itemImageContainer,
                    isComingSoon && { opacity: 0.5 }
                  ]}
                >
                  {item.icon && (
                    <Image
                      source={item.icon}
                      style={styles.itemImage}
                      resizeMode="contain"
                    />
                  )}
                </View>

                {/* ═════════════════════════════════════════════ */}
                {/* PRICE AREA - 40px height */}
                {/* ═════════════════════════════════════════════ */}
                {isComingSoon ? (
                  // Coming Soon Badge
                  <View
                    style={[
                      styles.itemPriceContainer,
                      { backgroundColor: '#555' }
                    ]}
                  >
                    <Text
                      style={[
                        styles.shopItemPrice,
                        { fontSize: 10, color: '#FFF' }
                      ]}
                    >
                      COMING SOON
                    </Text>
                  </View>
                ) : (
                  // Price or Equipped Status
                  <View style={styles.itemPriceContainer}>
                    {item.status === 'equipped' ? (
                      <Text style={styles.shopItemPrice}>EQUIPPED</Text>
                    ) : (
                      <View style={{ flexDirection: 'row', alignItems: 'center' }}>
                        <Text style={styles.shopItemPrice}>{item.price} </Text>
                        {item.price !== '0' && (
                          <Image
                            source={require('../asset/image/icon-coin.png')}
                            style={{ width: 14, height: 14, marginLeft: 2 }}
                            resizeMode="contain"
                          />
                        )}
                      </View>
                    )}
                  </View>
                )}
              </BounceButton>
            </View>
          );
        })}
      </View>
    </ScrollView>
  );

  const renderPackTab = () => (
    <ScrollView style={styles.packList} showsVerticalScrollIndicator={false}>
      {packs.map((pack) => (
        <View key={pack.id} style={styles.packItemWrapper}>
          <BounceButton onPress={() => handleBuyPack(pack)}>
            <View style={styles.packItemContainer}>
              <View style={styles.packItemRewards}>
                {pack.rewards.map((reward, idx) => (
                  <View key={idx} style={styles.packRewardItem}>
                    <Image source={reward.icon} style={styles.packRewardIcon} resizeMode="contain" />
                    {reward.qty && reward.qty > 1 && (
                      <View style={styles.badgeQuantity}>
                        <Text style={styles.badgeText}>{reward.qty}</Text>
                      </View>
                    )}
                  </View>
                ))}
              </View>
              <View style={styles.packPriceContainer}>
                <Text style={styles.packPriceText}>{pack.price}</Text>
              </View>
            </View>
          </BounceButton>
        </View>
      ))}
    </ScrollView>
  );

  return (
    <>
      <Animated.View style={[styles.shopPopup, { opacity, transform: [{ scale }] }]}>

        {/* Close Button */}
        <View style={styles.failedCloseBtn}>
          <BounceButton onPress={onClose}>
            <Image source={require('../asset/image/btn-close-red.png')} style={{ width: 44, height: 44 }} resizeMode="contain" />
          </BounceButton>
        </View>

        {/* Tabs */}
        <View style={styles.tabsHeaderContainer}>
          <TouchableOpacity style={[styles.tabButton, activeTab === 'ITEMS' && styles.activeTabButton]} onPress={() => setActiveTab('ITEMS')}>
            <Text style={[styles.tabText, activeTab === 'ITEMS' && styles.activeTabText]}>ITEMS</Text>
          </TouchableOpacity>
          <TouchableOpacity style={[styles.tabButton, activeTab === 'PACK' && styles.activeTabButton]} onPress={() => setActiveTab('PACK')}>
            <Text style={[styles.tabText, activeTab === 'PACK' && styles.activeTabText]}>PACK</Text>
          </TouchableOpacity>
        </View>

        {/* Body */}
        <View style={styles.shopBodyContainer}>
          <Text style={styles.shopHeaderTitle}>{activeTab === 'ITEMS' ? 'ITEMS' : 'SPECIAL OFFERS'}</Text>
          {activeTab === 'ITEMS' ? renderItemsTab() : renderPackTab()}
        </View>

      </Animated.View>

      {/* ADS BANNER */}
      {!isNoAdsPurchased && !(typeof window !== 'undefined' && (window as any).__autoTestActive) && (
        <View style={styles.shopAdsPlaceholder}>
          <BannerAd
            unitId={AdMobConfig.bannerAdUnitId}
            size={BannerAdSize.LARGE_BANNER}
            requestOptions={{
              requestNonPersonalizedAdsOnly: true,
            }}
          />
        </View>
      )}
    </>
  );
}

// -----------------------------------------------------------------------------
// GAMESCREEN & MOSQUITO COMPONENTS
// -----------------------------------------------------------------------------

// ═══════════════════════════════════════════════════════════════
// DAMAGE TEXT COMPONENT - Floating damage numbers
// ═══════════════════════════════════════════════════════════════
function DamageText({
  damage,
  x,
  y,
  isRedNails
}: {
  damage: number;
  x: number;
  y: number;
  isRedNails: boolean;
}) {
  const translateY = useRef(new Animated.Value(0)).current;
  const opacity = useRef(new Animated.Value(1)).current;

  useEffect(() => {
    // Animate text floating upward and fading out
    Animated.parallel([
      Animated.timing(translateY, {
        toValue: -50, // Float up 50 pixels
        duration: 800,
        easing: Easing.out(Easing.ease),
        useNativeDriver: true,
      }),
      Animated.timing(opacity, {
        toValue: 0, // Fade to transparent
        duration: 800,
        easing: Easing.out(Easing.ease),
        useNativeDriver: true,
      }),
    ]).start();
  }, []);

  return (
    <Animated.View
      style={{
        position: 'absolute',
        left: x,
        top: y,
        transform: [{ translateY }],
        opacity,
        zIndex: 1000,
        pointerEvents: 'none', // Don't block touch events
      }}
    >
      {/* ═══════════════════════════════════════════════════ */}
      {/* DAMAGE TEXT WITH STROKE EFFECT */}
      {/* ═══════════════════════════════════════════════════ */}
      <View style={{ position: 'relative', alignItems: 'center', justifyContent: 'center' }}>
        {/* Black stroke (4 layers for thick outline) */}
        <Text style={{
          position: 'absolute',
          fontFamily: 'LuckiestGuy',
          fontSize: 32,
          fontWeight: 'bold',
          color: '#000',
          top: -2,
          left: -2,
        }}>
          -{damage}
        </Text>
        <Text style={{
          position: 'absolute',
          fontFamily: 'LuckiestGuy',
          fontSize: 32,
          fontWeight: 'bold',
          color: '#000',
          top: -2,
          right: -2,
        }}>
          -{damage}
        </Text>
        <Text style={{
          position: 'absolute',
          fontFamily: 'LuckiestGuy',
          fontSize: 32,
          fontWeight: 'bold',
          color: '#000',
          bottom: -2,
          left: -2,
        }}>
          -{damage}
        </Text>
        <Text style={{
          position: 'absolute',
          fontFamily: 'LuckiestGuy',
          fontSize: 32,
          fontWeight: 'bold',
          color: '#000',
          bottom: -2,
          right: -2,
        }}>
          -{damage}
        </Text>

        {/* Main text - WHITE or RED based on skin */}
        <Text style={{
          fontFamily: 'LuckiestGuy',
          fontSize: 32,
          fontWeight: 'bold',
          color: isRedNails ? '#FF0000' : '#FFFFFF', // RED for Red Nails, WHITE for others
          textShadowColor: '#000',
          textShadowOffset: { width: 2, height: 2 },
          textShadowRadius: 4,
        }}>
          -{damage}
        </Text>
      </View>
    </Animated.View>
  );
}

type MosquitoData = {
  id: string;
  type: 'basic' | 'gray' | 'red' | 'fat' | 'tanker' | 'bone' | 'fast' | 'tiny' | 'ghost' | 'zigzag' | 'thief' | 'poison';
  hp: number;
  startX: number;
  startY: number;
  speed?: number;           // movement speed multiplier (default 1)
  movementPattern?: string; // 'normal' | 'zigzag'
};

// --- Child Component: 1 Con Muỗi ---
function Mosquito({
  data,
  playAreaWidth,
  playAreaHeight,
  onKill,
  isRacketActive,
  equippedSkin,
  isPaused,
}: {
  data: MosquitoData;
  playAreaWidth: number;
  playAreaHeight: number;
  onKill: (id: string, gold: number, effect?: string) => void;
  isRacketActive: boolean;
  equippedSkin: string;
  isPaused: boolean;
}) {
  const [hp, setHp] = useState(data.hp);
  const [clapVisible, setClapVisible] = useState(false);
  const [ghostOpacity, setGhostOpacity] = useState(1);
  const pos = useRef(new Animated.ValueXY({ x: data.startX, y: data.startY })).current;

  // ═══════════════════════════════════════════════════════════
  // DAMAGE TEXT STATE
  // ═══════════════════════════════════════════════════════════
  const [damageTexts, setDamageTexts] = useState<Array<{
    id: string;
    damage: number;
    x: number;
    y: number;
    isRedNails: boolean;
  }>>([]);

  // Size based on type
  const size =
    data.type === 'fat' || data.type === 'tanker' || data.type === 'bone' ? 70 :
      data.type === 'tiny' ? 35 :
        data.type === 'gray' ? 60 : 50;

  // Ghost flicker
  useEffect(() => {
    if (data.type !== 'ghost') return;
    const flickerInterval = setInterval(() => {
      setGhostOpacity(prev => prev === 1 ? 0.3 : 1);
    }, 800);
    return () => clearInterval(flickerInterval);
  }, [data.type]);

  // Thief escape timer with pause support
  const [thiefSecondsLeft, setThiefSecondsLeft] = useState(3);

  useEffect(() => {
    if (data.type !== 'thief') return;
    if (thiefSecondsLeft <= 0) return;
    if (isPaused) return; // Don't countdown when paused

    const interval = setInterval(() => {
      setThiefSecondsLeft(prev => {
        const newVal = prev - 1;
        if (newVal <= 0 && hp > 0) {
          playSound('lose');
          triggerVibration('error');
          onKill(data.id, -5, 'thief_escape');
          return 0;
        }
        return newVal;
      });
    }, 1000);

    return () => clearInterval(interval);
  }, [data.type, thiefSecondsLeft, isPaused, hp, data.id, onKill]);

  // Movement loop
  useEffect(() => {
    let isActive = true;
    const speedMultiplier = data.speed || 1;

    const flyToNewPosition = () => {
      if (!isActive) return;

      const baseDuration = 600 + Math.random() * 400;
      const duration = baseDuration / speedMultiplier;

      let nextX: number;
      let nextY: number;

      if (data.movementPattern === 'zigzag') {
        const currentX = (pos.x as any)._value ?? data.startX;
        const currentY = (pos.y as any)._value ?? data.startY;
        const angle = Math.random() * Math.PI * 2;
        const distance = 80 + Math.random() * 40;
        nextX = Math.max(0, Math.min(playAreaWidth - size, currentX + Math.cos(angle) * distance));
        nextY = Math.max(0, Math.min(playAreaHeight - size, currentY + Math.sin(angle) * distance));
      } else {
        nextX = Math.random() * (playAreaWidth - size);
        nextY = Math.random() * (playAreaHeight - size);
      }

      Animated.timing(pos, {
        toValue: { x: nextX, y: nextY },
        duration,
        easing: data.movementPattern === 'zigzag' ? Easing.linear : Easing.inOut(Easing.quad),
        useNativeDriver: false,
      }).start(({ finished }) => {
        if (finished && isActive) flyToNewPosition();
      });
    };

    flyToNewPosition();
    return () => { isActive = false; pos.stopAnimation(); };
  }, [playAreaWidth, playAreaHeight, data.speed, data.movementPattern, size]);

  const handlePress = () => {
    if (hp <= 0) return;

    let damage = 1;
    if (equippedSkin === 'tattoo') damage = 3;
    if (isRacketActive) damage = 9999;

    const newHp = Math.max(0, hp - damage);
    setHp(newHp);
    triggerVibration('light');
    playSound('splat');
    playSound('coin');

    // ═══════════════════════════════════════════════════════
    // CREATE DAMAGE TEXT
    // ═══════════════════════════════════════════════════════
    const damageTextId = `damage-${Date.now()}-${Math.random()}`;
    const isRedNails = equippedSkin === 'rednails';

    // Position text in center of mosquito
    const textX = size / 2 - 20; // Offset to center text
    const textY = size / 2 - 20;

    setDamageTexts(prev => [...prev, {
      id: damageTextId,
      damage: damage === 9999 ? 1 : damage, // Show actual damage (not 9999 for racket)
      x: textX,
      y: textY,
      isRedNails,
    }]);

    // Remove text after animation completes (800ms duration)
    setTimeout(() => {
      setDamageTexts(prev => prev.filter(t => t.id !== damageTextId));
    }, 850); // Slightly longer than animation duration

    setClapVisible(true);
    setTimeout(() => {
      setClapVisible(false);
      if (newHp === 0) {
        let goldVal = 1;
        let effect: string | undefined;

        if (data.type === 'fat') goldVal = 3;
        else if (data.type === 'tanker' || data.type === 'bone') goldVal = 5;
        else if (data.type === 'thief') goldVal = 3;

        if (data.type === 'poison') effect = 'poison';

        onKill(data.id, goldVal, effect);
      }
    }, 200);
  };

  // Image source mapping
  let imageSource: any = require('../asset/image/mob-basic.png');
  if (data.type === 'basic') imageSource = require('../asset/image/mob-basic.png');
  else if (data.type === 'gray') imageSource = require('../asset/image/mosquito-gray.png');
  else if (data.type === 'red') imageSource = require('../asset/image/mosquito-red.png');
  else if (data.type === 'fat') imageSource = require('../asset/image/mob-fat.png');
  else if (data.type === 'tanker') imageSource = require('../asset/image/mob-tanker.png');
  else if (data.type === 'bone') imageSource = require('../asset/image/mob-bone.png');
  else if (data.type === 'fast') imageSource = require('../asset/image/mob-fast.png');
  else if (data.type === 'tiny') imageSource = require('../asset/image/mob-tiny.png');
  else if (data.type === 'ghost') imageSource = require('../asset/image/mob-ghost.png');
  else if (data.type === 'zigzag') imageSource = require('../asset/image/mob-zigzag.png');
  else if (data.type === 'thief') imageSource = require('../asset/image/mob-thief.png');
  else if (data.type === 'poison') imageSource = require('../asset/image/mob-poison.png');

  if (hp <= 0 && !clapVisible) return null;

  return (
    <Animated.View
      style={[
        styles.mosquitoWrapper,
        {
          left: pos.x,
          top: pos.y,
          opacity: data.type === 'ghost' ? ghostOpacity : 1,
        },
      ]}
    >
      <TouchableOpacity activeOpacity={1} onPress={handlePress}>
        <Image source={imageSource} style={{ width: size, height: size }} resizeMode="contain" />

        {/* ═══════════════════════════════════════════════════ */}
        {/* CLAP EFFECT */}
        {/* ═══════════════════════════════════════════════════ */}
        {clapVisible && (
          <Image
            source={require('../asset/image/effect-clap.png')}
            style={styles.clapEffect}
            resizeMode="contain"
          />
        )}

        {/* ═══════════════════════════════════════════════════ */}
        {/* DAMAGE TEXTS - Multiple can exist simultaneously */}
        {/* ═══════════════════════════════════════════════════ */}
        {damageTexts.map(text => (
          <DamageText
            key={text.id}
            damage={text.damage}
            x={text.x}
            y={text.y}
            isRedNails={text.isRedNails}
          />
        ))}
      </TouchableOpacity>
    </Animated.View>
  );
}

// --- Boss Component ---
function BossMosquito({
  level,
  equippedSkin,
  playAreaWidth,
  playAreaHeight,
  onDefeat,
  isRacketActive
}: {
  level: number,
  equippedSkin: string,
  playAreaWidth: number,
  playAreaHeight: number,
  onDefeat: () => void,
  isRacketActive: boolean
}) {
  const maxHp = 200 + (level * 50);
  const [hp, setHp] = useState(maxHp);
  const [flash, setFlash] = useState(false);

  // ═══════════════════════════════════════════════════════════
  // DAMAGE TEXT STATE FOR BOSS
  // ═══════════════════════════════════════════════════════════
  const [damageTexts, setDamageTexts] = useState<Array<{
    id: string;
    damage: number;
    x: number;
    y: number;
    isRedNails: boolean;
  }>>([]);

  const shakeAnim = useRef(new Animated.Value(0)).current;
  const pos = useRef(new Animated.ValueXY({
    x: playAreaWidth / 2 - 100,
    y: playAreaHeight / 2 - 100
  })).current;

  // Render variables
  const imageSource = level % 2 === 0
    ? require('../asset/image/mob-bone.png')
    : require('../asset/image/mob-tanker.png');

  useEffect(() => {
    // Random flight loop for boss
    let isActive = true;
    const flyToNewPosition = () => {
      if (!isActive) return;

      const nextX = Math.random() * (playAreaWidth - 200);
      const nextY = Math.random() * (playAreaHeight - 200);
      // Slower movement for boss
      const duration = 1500 + Math.random() * 1000;

      Animated.timing(pos, {
        toValue: { x: Math.max(0, nextX), y: Math.max(0, nextY) },
        duration,
        easing: Easing.inOut(Easing.quad),
        useNativeDriver: false,
      }).start(({ finished }) => {
        if (finished && isActive) flyToNewPosition();
      });
    };
    if (playAreaWidth > 0 && playAreaHeight > 0) {
      flyToNewPosition();
    }

    return () => {
      isActive = false;
      pos.stopAnimation();
    };
  }, [playAreaWidth, playAreaHeight]);

  const handlePress = () => {
    if (hp <= 0) return;

    let damage = equippedSkin === 'tattoo' ? 3 : 1;
    if (isRacketActive) damage = 9999;

    const newHp = Math.max(0, hp - damage);
    setHp(newHp);

    // Sound + Haptics (Boss)
    triggerVibration('heavy');
    playSound('bossHit');

    // ═══════════════════════════════════════════════════════
    // CREATE DAMAGE TEXT FOR BOSS
    // ═══════════════════════════════════════════════════════
    const damageTextId = `damage-${Date.now()}-${Math.random()}`;
    const isRedNails = equippedSkin === 'rednails';

    // Position text in center of boss (boss is 60px * 3 scale = 180px)
    const textX = 90 - 20; // Center of scaled boss
    const textY = 90 - 20;

    setDamageTexts(prev => [...prev, {
      id: damageTextId,
      damage: damage === 9999 ? 1 : damage,
      x: textX,
      y: textY,
      isRedNails,
    }]);

    // Remove text after animation
    setTimeout(() => {
      setDamageTexts(prev => prev.filter(t => t.id !== damageTextId));
    }, 850);

    // Chớp sáng đỏ
    setFlash(true);
    setTimeout(() => setFlash(false), 50);

    // Rung (Shake)
    shakeAnim.setValue(0);
    Animated.sequence([
      Animated.timing(shakeAnim, { toValue: 10, duration: 40, useNativeDriver: true }),
      Animated.timing(shakeAnim, { toValue: -10, duration: 40, useNativeDriver: true }),
      Animated.timing(shakeAnim, { toValue: 10, duration: 40, useNativeDriver: true }),
      Animated.timing(shakeAnim, { toValue: 0, duration: 40, useNativeDriver: true })
    ]).start();

    if (newHp === 0) {
      onDefeat();
    }
  };

  const hpPercentage = (hp / maxHp) * 100;

  if (hp <= 0) return null;

  return (
    <View style={StyleSheet.absoluteFill}>
      {/* Boss Vector Position */}
      <Animated.View style={[
        styles.mosquitoWrapper,
        {
          left: pos.x,
          top: pos.y,
          transform: [{ translateX: shakeAnim }]
        }
      ]}>
        <TouchableOpacity activeOpacity={1} onPress={handlePress}>
          <Image
            source={imageSource}
            style={{ width: 60, height: 60, transform: [{ scale: 3 }], opacity: flash ? 0.5 : 1 }}
            resizeMode="contain"
          />

          {/* ═══════════════════════════════════════════════ */}
          {/* DAMAGE TEXTS FOR BOSS */}
          {/* ═══════════════════════════════════════════════ */}
          {damageTexts.map(text => (
            <DamageText
              key={text.id}
              damage={text.damage}
              x={text.x}
              y={text.y}
              isRedNails={text.isRedNails}
            />
          ))}
        </TouchableOpacity>
      </Animated.View>

      {/* HP Bar */}
      <View style={styles.bossHpContainer}>
        <View style={[styles.bossHpBar, { width: `${hpPercentage}%` }]} />
        <Text style={styles.bossHpText}>{hp} / {maxHp}</Text>
      </View>
    </View>
  );
}

// TARGET and SPAWN RATE are now computed dynamically per level inside GameScreen

// --- Main Game Component ---
function GameScreen({ hearts, decreaseHeart, addHeart, onBack, globalGold, updateGold, currentLevel, updateLevel, equippedSkin, inventory, updateInventory, freeTrials, updateFreeTrials, showInterstitialAd, showRewardedAd, isNoAdsPurchased }: { hearts: number, decreaseHeart: () => void, addHeart: () => void, onBack: () => void, globalGold: number, updateGold: (v: number) => void, currentLevel: number, updateLevel: (v: number) => void, equippedSkin: string, inventory: { [key: string]: number }, updateInventory: (inv: { [key: string]: number }) => void, freeTrials: { [key: string]: boolean }, updateFreeTrials: (trials: { [key: string]: boolean }) => void, showInterstitialAd: (cb: () => void) => void, showRewardedAd: (cb: () => void) => void, isNoAdsPurchased: boolean }) {
  // Level-based formula
  const TARGET_MOSQUITO = 20 + currentLevel * 5;
  const SPAWN_INTERVAL = Math.max(200, 1000 - currentLevel * 40);

  const [timeLeft, setTimeLeft] = useState(30);
  const [playAreaSize, setPlayAreaSize] = useState({ width: 0, height: 0 });
  const [mosquitos, setMosquitos] = useState<MosquitoData[]>([]);
  const [kills, setKills] = useState(0);
  const [earnedGold, setEarnedGold] = useState(0);
  const [isCompleted, setIsCompleted] = useState(false);
  const [isFailed, setIsFailed] = useState(false);
  const [isQuitPopupVisible, setIsQuitPopupVisible] = useState(false);
  const [bossDefeated, setBossDefeated] = useState(false);
  const [isRacketActive, setIsRacketActive] = useState(false);
  const [racketSecondsLeft, setRacketSecondsLeft] = useState(0);
  const [isPoisonActive, setIsPoisonActive] = useState(false);

  // AUTO-TEST MODE (only for web testing - does not affect builds)
  const [autoTestActive, setAutoTestActive] = useState(false);
  const [testSpeed, setTestSpeed] = useState(1);
  const [testStartTime, setTestStartTime] = useState(0);
  const [testReport, setTestReport] = useState({
    levelsCompleted: [] as number[],
    mosquitosEncountered: [] as string[],
    itemsUsed: [] as string[],
    freeTrialsReceived: [] as number[],
    bossDefeated: false,
    totalKills: 0
  });

  // isPaused: suspend timer and spawn during quit popup
  const isPaused = isQuitPopupVisible;

  const [depletedItemsThisLevel, setDepletedItemsThisLevel] = useState<string[]>([]);

  // ═══════════════════════════════════════════════════════════
  // FREE TRIALS - Grant items at specific levels
  // ═══════════════════════════════════════════════════════════
  useEffect(() => {
    // Skip if not at start of level
    if (timeLeft !== 30) return;

    let itemToGive: string | null = null;
    let itemName = "";
    let trialKey = "";
    let title = "";
    let msg = "";

    if (currentLevel === 3 && !freeTrials['level3']) {
      itemToGive = 'item-racket';
      itemName = "Electric Racket";
      title = "🎁 Free Trial!";
      msg = "Here is an Electric Racket! Tap it to kill mosquitoes easily!";
      trialKey = 'level3';
    } else if (currentLevel === 5 && !freeTrials['level5']) {
      itemToGive = 'item-coil';
      itemName = "Mosquito Coil";
      title = "🎁 Free Trial!";
      msg = "Take this Mosquito Coil to clear out multiple bugs!";
      trialKey = 'level5';
    } else if (currentLevel === 7 && !freeTrials['level7']) {
      itemToGive = 'item-spray';
      title = "🎁 Free Trial!";
      msg = "Use this Bug Spray for an instant screen clear!";
      trialKey = 'level7';
    }

    if (itemToGive) {
      const newInventory = { ...inventory };
      newInventory[itemToGive] = (newInventory[itemToGive] || 0) + 1;
      updateInventory(newInventory);

      const newTrials = { ...freeTrials, [trialKey]: true };
      updateFreeTrials(newTrials);

      Alert.alert(title, msg);
    }
  }, [currentLevel, timeLeft, inventory, updateInventory, freeTrials, updateFreeTrials]);

  // ═══════════════════════════════════════════════════════════
  // ELECTRIC RACKET COUNTDOWN WITH PAUSE/RESUME SUPPORT
  // ═══════════════════════════════════════════════════════════
  useEffect(() => {
    // Exit conditions
    if (racketSecondsLeft <= 0) {
      setIsRacketActive(false);
      return;
    }

    // Pause when quit popup is open
    if (isPaused) return;

    // Countdown every 1 second
    const interval = setInterval(() => {
      setRacketSecondsLeft(prev => {
        const newVal = prev - 1;
        if (newVal <= 0) {
          setIsRacketActive(false);
          return 0;
        }
        return newVal;
      });
    }, 1000);

    // Cleanup
    return () => clearInterval(interval);
  }, [racketSecondsLeft, isPaused]);

  const isBossLevel = currentLevel % 3 === 0;

  const mosquitosRef = useRef(mosquitos);
  mosquitosRef.current = mosquitos; // Keep ref updated for intervals

  const totalSpawnedRef = useRef(0);

  const spawnMosquito = useCallback(() => {
    if (playAreaSize.width === 0 || playAreaSize.height === 0) return;
    if (totalSpawnedRef.current >= TARGET_MOSQUITO) return;

    const rand = Math.random();
    type SpawnType = MosquitoData['type'];
    let type: SpawnType = 'basic';
    let hp = 1;
    let speed: number | undefined;
    let movementPattern: string | undefined;

    // Rarity table (cumulative probabilities)
    if (rand < 0.04) { type = 'poison'; hp = 1; }                               // 4%  rare
    else if (rand < 0.08) { type = 'thief'; hp = 1; speed = 1.5; }                  // 4%  rare
    else if (rand < 0.12) { type = 'bone'; hp = 5; speed = 0.6; }                  // 4%  rare
    else if (rand < 0.16) { type = 'ghost'; hp = 1; speed = 1.2; }                  // 4%  rare
    else if (rand < 0.20) { type = 'zigzag'; hp = 1; movementPattern = 'zigzag'; }    // 4%  rare
    else if (rand < 0.25) { type = 'fast'; hp = 1; speed = 2.5; }                  // 5%  uncommon
    else if (rand < 0.31) { type = 'tanker'; hp = 3; speed = 0.7; }                  // 6%  uncommon
    else if (rand < 0.41) { type = 'fat'; hp = 1; speed = 0.8; }                  // 10% uncommon
    else if (rand < 0.51) { type = 'red'; hp = 3; }                               // 10% uncommon
    else if (rand < 0.58) { type = 'tiny'; hp = 1; speed = 1.3; }                  // 7%  uncommon
    else if (rand < 0.79) { type = 'gray'; hp = 1; }                               // 21% common
    else { type = 'basic'; hp = 1; }                               // 21% common

    const size =
      type === 'fat' || type === 'tanker' || type === 'bone' ? 70 :
        type === 'tiny' ? 35 : 50;

    const startX = Math.random() * (playAreaSize.width - size);
    const startY = Math.random() * (playAreaSize.height - size);

    const newMosquito: MosquitoData = {
      id: Math.random().toString(),
      type,
      hp,
      startX,
      startY,
      ...(speed !== undefined && { speed }),
      ...(movementPattern !== undefined && { movementPattern }),
    };

    totalSpawnedRef.current += 1;
    setMosquitos((prev) => [...prev, newMosquito]);
  }, [playAreaSize, TARGET_MOSQUITO]);

  useEffect(() => {
    // Timer Loop
    if (isPaused || timeLeft <= 0 || isCompleted || isFailed || isQuitPopupVisible) {
      if (timeLeft <= 0 && !isCompleted && !isFailed && !isPaused) {
        playSound('lose');
        triggerVibration('error');
        showInterstitialAd(() => setIsFailed(true));
      }
      return;
    }

    const timerId = setTimeout(() => {
      setTimeLeft(timeLeft - 1);
    }, 1000);

    return () => clearTimeout(timerId);
  }, [timeLeft, isCompleted, isFailed, isQuitPopupVisible, isPaused]);

  const handleTryAgain = () => {
    decreaseHeart();
    setTimeLeft(30);
    setIsFailed(false);
    setMosquitos([]);
    setKills(0);
    totalSpawnedRef.current = 0;
  };

  const handleCloseFail = () => {
    decreaseHeart();
    onBack();
  };

  const handleWatchAd = () => {
    // Giả lập xem ads xong được +1 tim và chơi tiếp
    addHeart();
    setTimeLeft(30);
    setIsFailed(false);
    setMosquitos([]);
    setKills(0);
    totalSpawnedRef.current = 0;
  };

  useEffect(() => {
    // Initial burst to show mosquitos exactly at 30s
    if (playAreaSize.width > 0 && timeLeft === 30 && !isCompleted) {
      spawnMosquito();
      spawnMosquito(); // Spawn 2 immediately
    }
  }, [playAreaSize.width, timeLeft, isCompleted, spawnMosquito]);

  useEffect(() => {
    // Spawn Loop - level-based interval, paused when isPaused
    if (isPaused || playAreaSize.width === 0 || timeLeft <= 0 || isCompleted || isFailed || isQuitPopupVisible || isBossLevel) return;

    const intervalId = setInterval(() => {
      spawnMosquito();
    }, SPAWN_INTERVAL);

    return () => clearInterval(intervalId);
  }, [isPaused, playAreaSize, timeLeft, spawnMosquito, isBossLevel, SPAWN_INTERVAL]);

  const handleKill = useCallback((id: string, gold: number, effect?: string) => {
    setMosquitos((prev) => prev.filter(m => m.id !== id));

    // Negative gold = thief stole gold
    if (gold < 0) {
      setEarnedGold((prev) => Math.max(0, prev + gold));
    } else {
      setEarnedGold((prev) => prev + gold);
    }

    // Don't count thief escape as a kill
    if (effect !== 'thief_escape') {
      setKills((prev) => {
        const newKills = prev + 1;
        if (newKills >= TARGET_MOSQUITO) {
          playSound('win');
          showInterstitialAd(() => setIsCompleted(true));
        }
        return newKills;
      });
    }

    // Special effects
    if (effect === 'poison') {
      setIsPoisonActive(true);
      triggerVibration('heavy');
      playSound('electric');
      setTimeout(() => setIsPoisonActive(false), 2000);
    } else if (effect === 'thief_escape') {
      triggerVibration('error');
      playSound('lose');
    }
  }, [TARGET_MOSQUITO, showInterstitialAd]);

  const handleBossDefeat = useCallback(() => {
    setBossDefeated(true);
    setEarnedGold(prev => prev + 50); // Màn Boss thưởng nóng 50 Vàng
    playSound('win');
    showInterstitialAd(() => setIsCompleted(true));
  }, [showInterstitialAd]);

  const handleQuitGame = () => {
    decreaseHeart();
    setIsQuitPopupVisible(false);
    onBack();
  };

  const formatTime = (seconds: number) => {
    return '00:' + (seconds < 10 ? '0' : '') + seconds;
  };

  // Define base active items for bottom bar
  const activeItems = ['item-racket', 'item-coil', 'item-spray'];

  // Filter for items we can render
  const renderableItems = activeItems.filter(item => {
    return (inventory && inventory[item] > 0) || depletedItemsThisLevel.includes(item);
  });

  const executeItemEffect = (itemName: string) => {
    const calcGold = (m: MosquitoData) => {
      if (m.type === 'fat' || m.type === 'thief') return 3;
      if (m.type === 'tanker' || m.type === 'bone') return 5;
      return 1;
    };

    if (itemName === 'spray') {
      let totalGold = 0;
      mosquitos.forEach(m => { totalGold += calcGold(m); });
      if (totalGold > 0) {
        setEarnedGold(prev => prev + totalGold);
        setKills(prev => {
          const newKills = prev + mosquitos.length;
          if (newKills >= TARGET_MOSQUITO) {
            playSound('win');
            showInterstitialAd(() => setIsCompleted(true));
          }
          return newKills;
        });
        setMosquitos([]);
        triggerVibration('success');
        playSound('electric');
      }
    } else if (itemName === 'coil') {
      if (mosquitos.length <= 5) {
        let totalGold = 0;
        mosquitos.forEach(m => { totalGold += calcGold(m); });
        if (totalGold > 0) {
          setEarnedGold(prev => prev + totalGold);
          setKills(prev => {
            const newKills = prev + mosquitos.length;
            if (newKills >= TARGET_MOSQUITO) {
              playSound('win');
              showInterstitialAd(() => setIsCompleted(true));
            }
            return newKills;
          });
          setMosquitos([]);
          triggerVibration('success');
          playSound('electric');
        }
      } else {
        const shuffled = [...mosquitos].sort(() => 0.5 - Math.random());
        const toKill = shuffled.slice(0, 5);
        const remaining = shuffled.slice(5);

        let totalGold = 0;
        toKill.forEach(m => { totalGold += calcGold(m); });

        setEarnedGold(prev => prev + totalGold);
        setKills(prev => {
          const newKills = prev + 5;
          if (newKills >= TARGET_MOSQUITO) showInterstitialAd(() => setIsCompleted(true));
          return newKills;
        });
        setMosquitos(remaining);
        triggerVibration('success');
      }
    } else if (itemName === 'racket') {
      setIsRacketActive(true);
      setRacketSecondsLeft(4); // Start 4-second countdown
    }
  };

  const handleWatchAdForItem = (itemName: string) => {
    showRewardedAd(() => {
      executeItemEffect(itemName);
      setDepletedItemsThisLevel(prev => prev.filter(i => i !== itemName));
    });
  };

  const onItemPress = (itemName: string) => {
    if (inventory && inventory[itemName] > 0) {
      executeItemEffect(itemName);

      const newInventory = { ...inventory };
      newInventory[itemName] -= 1;
      updateInventory(newInventory);

      if (newInventory[itemName] === 0) {
        setDepletedItemsThisLevel(prev => [...prev, itemName]);
      }
    } else if (depletedItemsThisLevel.includes(itemName)) {
      // Depleted: watch a rewarded ad to use 1 more time (Rule 3)
      handleWatchAdForItem(itemName);
    }
  };

  // Helper dictionary lookup cho item icons
  const getItemIcon = (itemName: string) => {
    switch (itemName) {
      case 'item-racket': return require('../asset/image/item-racket.png');
      case 'item-coil': return require('../asset/image/item-coil.png');
      case 'item-spray': return require('../asset/image/item-spray.png');
      case 'item-bomb': return require('../asset/image/icon-bomb.png');
      default: return null;
    }
  };

  return (
    <View style={styles.gameContainer}>
      {autoTestActive && (
        <View style={{
          position: 'absolute',
          top: 90,
          right: 15,
          backgroundColor: 'rgba(0,180,0,0.95)',
          padding: 10,
          borderRadius: 8,
          zIndex: 9999,
          borderWidth: 2,
          borderColor: '#0f0',
        }}>
          <Text style={{ color: '#fff', fontWeight: 'bold', fontSize: 12 }}>
            🤖 AUTO-TEST
          </Text>
          <Text style={{ color: '#fff', fontSize: 9 }}>
            Speed: {testSpeed}x
          </Text>
          <Text style={{ color: '#fff', fontSize: 9 }}>
            Lvl: {currentLevel}/10
          </Text>
          <Text style={{ color: '#fff', fontSize: 9 }}>
            Types: {testReport.mosquitosEncountered.length}/12
          </Text>
          <Text style={{ color: '#fff', fontSize: 9 }}>
            Items: {testReport.itemsUsed.length}/6
          </Text>
          <Text style={{ color: '#fff', fontSize: 8, marginTop: 3, opacity: 0.8 }}>
            F8:OFF F9:Speed F11:Report F12:Win
          </Text>
        </View>
      )}
      {/* Top Bar Game */}
      <View style={styles.gameTopBar}>
        <View style={styles.killsBadge}>
          {isBossLevel ? (
            <Text style={[styles.killsText, { color: '#F2B705' }]}>BOSS</Text>
          ) : (
            <Text style={styles.killsText}>{kills}/{TARGET_MOSQUITO}</Text>
          )}
        </View>
        <View style={styles.timerBadge}>
          <Text style={styles.timerText}>{formatTime(timeLeft)}</Text>
        </View>
        <BounceButton style={styles.gameSettingsBtn} onPress={() => setIsQuitPopupVisible(true)}>
          <Image source={require('../asset/image/icon-settings.png')} style={{ width: 32, height: 32 }} resizeMode="contain" />
        </BounceButton>
      </View>

      {/* Play Area */}
      <View style={[styles.playAreaBorder, isRacketActive && { borderColor: '#FFD700', borderWidth: 8 }]}>
        <View
          style={[styles.playArea, isRacketActive && { backgroundColor: '#4A4000' }]}
          onLayout={(e) => {
            const { width, height } = e.nativeEvent.layout;
            setPlayAreaSize({ width, height });
          }}
        >
          {/* Poison overlay */}
          {isPoisonActive && (
            <View style={{ position: 'absolute', top: 0, left: 0, right: 0, bottom: 0, backgroundColor: 'rgba(0,255,0,0.4)', zIndex: 999 }} />
          )}
          {isBossLevel && playAreaSize.width > 0 ? (
            <BossMosquito
              level={currentLevel}
              equippedSkin={equippedSkin}
              playAreaWidth={playAreaSize.width}
              playAreaHeight={playAreaSize.height}
              onDefeat={handleBossDefeat}
              isRacketActive={isRacketActive}
            />
          ) : (
            playAreaSize.width > 0 && mosquitos.map(m => (
              <Mosquito
                key={m.id}
                data={m}
                playAreaWidth={playAreaSize.width}
                playAreaHeight={playAreaSize.height}
                onKill={handleKill}
                isRacketActive={isRacketActive}
                equippedSkin={equippedSkin}
                isPaused={isPaused}
              />
            ))
          )}
        </View>
      </View>

      {/* Bottom Toolbar */}
      {renderableItems.length > 0 && (
        <View style={styles.bottomActionBar}>
          {renderableItems.map(itemName => {
            const hasStock = inventory[itemName] > 0;

            return (
              <BounceButton key={itemName} onPress={() => onItemPress(itemName)}>
                <View style={styles.actionItemButton}>
                  <Image
                    source={getItemIcon(itemName)}
                    style={[styles.actionItemImage, hasStock ? null : { opacity: 0.5 }]}
                  />
                  {hasStock ? (
                    <View style={styles.quantityBadge}>
                      <Text style={styles.quantityBadgeText}>{inventory[itemName]}</Text>
                    </View>
                  ) : (
                    <View style={styles.adsBadge}>
                      <Text style={styles.adsBadgeText}>▶ ADS</Text>
                    </View>
                  )}
                </View>
              </BounceButton>
            );
          })}
        </View>
      )}

      {/* Completed Popup Overlay */}
      {isCompleted && (
        <CompletedPopup
          onContinue={() => {
            updateGold(globalGold + earnedGold);
            updateLevel(currentLevel + 1);
            onBack();
          }}
          onGetX3={() => {
            updateGold(globalGold + (earnedGold * 3));
            updateLevel(currentLevel + 1);
            onBack();
          }}
          onClose={() => {
            updateGold(globalGold + earnedGold);
            updateLevel(currentLevel + 1);
            onBack();
          }}
          reward={earnedGold}
          isNoAdsPurchased={isNoAdsPurchased}
        />
      )}

      {/* Level Failed Popup Overlay */}
      {isFailed && <LevelFailedPopup onTryAgain={handleTryAgain} onClose={handleCloseFail} hearts={hearts} onWatchAd={handleWatchAd} isNoAdsPurchased={isNoAdsPurchased} />}

      {/* Quit Level Popup Overlay */}
      {isQuitPopupVisible && (
        <QuitLevelPopup
          onQuit={handleQuitGame}
          onClose={() => setIsQuitPopupVisible(false)}
        />
      )}
    </View>
  );
}

// --- Level Failed Popup Component ---
function LevelFailedPopup({ onTryAgain, onClose, hearts, onWatchAd, isNoAdsPurchased }: { onTryAgain: () => void, onClose: () => void, hearts: number, onWatchAd: () => void, isNoAdsPurchased: boolean }) {
  const scale = useRef(new Animated.Value(0.3)).current;
  const opacity = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.parallel([
      Animated.spring(scale, { toValue: 1, friction: 5, tension: 60, useNativeDriver: true }),
      Animated.timing(opacity, { toValue: 1, duration: 300, useNativeDriver: true })
    ]).start();
  }, []);

  return (
    <View style={styles.gamePopupOverlay}>
      <Animated.View style={[styles.failedPopup, { opacity, transform: [{ scale }] }]}>

        {/* Close Button */}
        <View style={styles.failedCloseBtn}>
          <BounceButton onPress={onClose}>
            <Image source={require('../asset/image/btn-close-red.png')} style={{ width: 44, height: 44 }} resizeMode="contain" />
          </BounceButton>
        </View>

        <Text style={styles.failedTitle}>LEVEL FAILED</Text>

        {/* Content Box */}
        <View style={styles.failedContentBox}>
          <Image source={require('../asset/image/icon-heart-broken.png')} style={{ width: 90, height: 90, marginRight: 15 }} resizeMode="contain" />
          <View style={styles.failedTextStrokeWrapper}>
            <Text style={styles.failedBoxTextStroke}>-1</Text>
            <Text style={styles.failedBoxTextStroke2}>-1</Text>
            <Text style={styles.failedBoxTextStroke3}>-1</Text>
            <Text style={styles.failedBoxTextStroke4}>-1</Text>
            <Text style={styles.failedBoxText}>-1</Text>
          </View>
        </View>

        {/* Action Button: TRY AGAIN or WATCH AD */}
        {hearts > 0 ? (
          <BounceButton onPress={onTryAgain} style={styles.tryAgainBtnWrapper}>
            <View style={styles.tryAgainBtn}>
              <Text style={styles.tryAgainText}>TRY AGAIN</Text>
            </View>
          </BounceButton>
        ) : (
          <BounceButton onPress={onWatchAd} style={styles.tryAgainBtnWrapper}>
            <View style={[styles.tryAgainBtn, { backgroundColor: '#F2B705' }]}>
              <Text style={[styles.tryAgainText, { color: '#000' }]}>WATCH AD TO CONTINUE</Text>
            </View>
          </BounceButton>
        )}

      </Animated.View>

      {/* ADS Banner at the bottom of the overlay */}
      {!isNoAdsPurchased && !(typeof window !== 'undefined' && (window as any).__autoTestActive) && (
        <View style={styles.adsPlaceholder}>
          <BannerAd
            unitId={AdMobConfig.bannerAdUnitId}
            size={BannerAdSize.LARGE_BANNER}
            requestOptions={{
              requestNonPersonalizedAdsOnly: true,
            }}
          />
        </View>
      )}
    </View>
  );
}

// --- Quit Level Popup Component ---
function QuitLevelPopup({ onQuit, onClose }: { onQuit: () => void, onClose: () => void }) {
  const scale = useRef(new Animated.Value(0.3)).current;
  const opacity = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.parallel([
      Animated.spring(scale, { toValue: 1, friction: 5, tension: 60, useNativeDriver: true }),
      Animated.timing(opacity, { toValue: 1, duration: 300, useNativeDriver: true })
    ]).start();
  }, []);

  return (
    <View style={styles.gamePopupOverlay}>
      <Animated.View style={[styles.failedPopup, { opacity, transform: [{ scale }] }]}>

        {/* Close Button */}
        <View style={styles.failedCloseBtn}>
          <BounceButton onPress={onClose}>
            <Image source={require('../asset/image/btn-close-red.png')} style={{ width: 44, height: 44 }} resizeMode="contain" />
          </BounceButton>
        </View>

        <Text style={styles.failedTitle}>QUIT LEVEL</Text>

        {/* Content Box */}
        <View style={[styles.failedContentBox, { flexDirection: 'column', paddingVertical: 15 }]}>
          <Image source={require('../asset/image/icon-heart-broken.png')} style={{ width: 70, height: 70, marginBottom: 5 }} resizeMode="contain" />
          <View style={styles.failedTextStrokeWrapper}>
            <Text style={styles.quitWarningTextStroke}>You will lose a life!</Text>
            <Text style={styles.quitWarningTextStroke2}>You will lose a life!</Text>
            <Text style={styles.quitWarningTextStroke3}>You will lose a life!</Text>
            <Text style={styles.quitWarningTextStroke4}>You will lose a life!</Text>
            <Text style={styles.quitWarningText}>You will lose a life!</Text>
          </View>
        </View>

        {/* QUIT Button */}
        <BounceButton onPress={onQuit} style={styles.tryAgainBtnWrapper}>
          <View style={styles.tryAgainBtn}>
            <Text style={styles.tryAgainText}>QUIT</Text>
          </View>
        </BounceButton>

      </Animated.View>
    </View>
  );
}

// --- Completed Popup Component ---
function CompletedPopup({ onContinue, onGetX3, onClose, reward, isNoAdsPurchased }: { onContinue: () => void, onGetX3: () => void, onClose: () => void, reward: number, isNoAdsPurchased: boolean }) {
  const scale = useRef(new Animated.Value(0.3)).current;
  const opacity = useRef(new Animated.Value(0)).current;

  useEffect(() => {
    Animated.parallel([
      Animated.spring(scale, { toValue: 1, friction: 5, tension: 60, useNativeDriver: true }),
      Animated.timing(opacity, { toValue: 1, duration: 300, useNativeDriver: true })
    ]).start();
  }, []);



  return (
    <View style={styles.gamePopupOverlay}>
      <Animated.View style={[styles.completedPopup, { opacity, transform: [{ scale }] }]}>

        {/* Close Button */}
        <View style={styles.completedCloseBtn}>
          <BounceButton onPress={onClose}>
            <Image source={require('../asset/image/btn-close-red.png')} style={{ width: 44, height: 44 }} resizeMode="contain" />
          </BounceButton>
        </View>

        <Text style={styles.completedTitle}>COMPLETED</Text>

        {/* Reward Box */}
        <View style={styles.rewardBox}>
          <Image source={require('../asset/image/icon-coin.png')} style={{ width: 40, height: 40, marginRight: 10 }} resizeMode="contain" />
          <Text style={styles.rewardBoxText}>x{reward}</Text>
        </View>

        {/* Buttons */}
        <BounceButton onPress={onContinue} style={{ marginBottom: 15, width: '100%', alignItems: 'center' }}>
          <Image source={require('../asset/image/btn-continue.png')} style={{ width: 220, height: 65 }} resizeMode="contain" />
        </BounceButton>

        <BounceButton onPress={onGetX3} style={{ width: '100%', alignItems: 'center' }}>
          <Image source={require('../asset/image/btn-get-x3.png')} style={{ width: 220, height: 65 }} resizeMode="contain" />
        </BounceButton>

      </Animated.View>

      {/* ADS Banner at the bottom of the overlay */}
      {!isNoAdsPurchased && !(typeof window !== 'undefined' && (window as any).__autoTestActive) && (
        <View style={styles.adsPlaceholder}>
          <BannerAd
            unitId={AdMobConfig.bannerAdUnitId}
            size={BannerAdSize.LARGE_BANNER}
            requestOptions={{
              requestNonPersonalizedAdsOnly: true,
            }}
          />
        </View>
      )}
    </View>
  );
}

